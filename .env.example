# GitHub Personal Access Token (PAT)
# Required for accessing GitHub API and showing private stats
# Get your token from: https://github.com/settings/tokens
PAT_1=your_github_personal_access_token_here

# Optional: Additional PAT tokens for load balancing
# PAT_2=your_second_token_here
# PAT_3=your_third_token_here

# Server Port (default: 9000)
PORT=9000

# Cache duration in seconds
# Default: 21600 (6 hours)
# Set to 0 to disable caching
CACHE_SECONDS=21600

# Whitelist specific GitHub usernames (comma-separated)
# If not set, all usernames are allowed
# WHITELIST=username1,username2,username3

# Whitelist specific Gist IDs (comma-separated)
# If not set, all Gist IDs are allowed
# GIST_WHITELIST=gist_id_1,gist_id_2

# Exclude specific repositories from stats (comma-separated)
# Useful for privacy in self-hosted instances
# EXCLUDE_REPO=repo1,repo2,repo3

# Fetch multi-page stars (true/false)
# Enables fetching all starred repositories for accurate star counts
# May increase response times and API usage
# FETCH_MULTI_PAGE_STARS=false
